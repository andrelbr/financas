# Configuração para o Vercel (Production)
# Configure estas variáveis no painel do Vercel na aba "Environment Variables"

# 1. Chave secreta para JWT (Gere uma chave segura)
JWT_SECRET=sua_chave_secreta_super_forte_aqui

# 2. String de Conexão com Banco de Dados PostgreSQL 
# (Supabase, Neon, ou qualquer provedor Postgres)
DATABASE_URL=postgresql://usuario:senha@host:5432/nomedobanco
